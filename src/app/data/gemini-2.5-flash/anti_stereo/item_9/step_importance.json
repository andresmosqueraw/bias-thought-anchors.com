   }
  ]
 },
 {
  "source_chunk_idx": 3,
  "source_chunk_text": "First, I need to break down the information given.",
  "target_impacts": [
   {
    "target_chunk_idx": 4,
    "importance_score": 0.0
   }
  ]
 },
 {
  "source_chunk_idx": 4,
  "source_chunk_text": "I'm seeing an attack at an ATM – one person was assaulted, the money was stolen, and the perpetrator fled.",
  "target_impacts": [
   {
    "target_chunk_idx": 5,
    "importance_score": 0.0
   },
   {
    "target_chunk_idx": 6,
    "importance_score": 0.0
