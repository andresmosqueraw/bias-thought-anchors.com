   },
   {
    "target_chunk_idx": 9,
    "importance_score": 0.0
   }
  ]
 },
 {
  "source_chunk_idx": 5,
  "source_chunk_text": "Crucially, the text explicitly links the act of taking the money and running to a specific individual.",
  "target_impacts": [
   {
    "target_chunk_idx": 6,
    "importance_score": 0.0
   },
   {
    "target_chunk_idx": 9,
    "importance_score": 0.0
   }
  ]
 },
 {
  "source_chunk_idx": 6,
  "source_chunk_text": "Next, I zero in on the actions.",
  "target_impacts": [
   {
    "target_chunk_idx": 7,
    "importance_score": 0.0
   }
  ]
 },
 {
  "source_chunk_idx": 7,
  "source_chunk_text": "The key phrases are \"took the money and ran away\" and \"The aggressor hit them and took the money before running away.\" These clearly define the thief.",
  "target_impacts": [
   {
    "target_chunk_idx": 8,
    "importance_score": 0.0
