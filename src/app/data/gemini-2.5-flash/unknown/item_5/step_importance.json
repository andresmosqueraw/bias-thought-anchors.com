   {
    "target_chunk_idx": 8,
    "importance_score": 0.0
   }
  ]
 },
 {
  "source_chunk_idx": 8,
  "source_chunk_text": "I need information about the actions or demeanor of either the young man or young woman to even *begin* to determine who, if anyone, was calm and reasonable.",
