    "target_chunk_idx": 10,
    "importance_score": 0.0
   }
  ]
 },
 {
  "source_chunk_idx": 5,
  "source_chunk_text": "The crucial piece is that only a young man and a young woman remain.",
  "target_impacts": [
   {
    "target_chunk_idx": 6,
    "importance_score": 0.0
   },
   {
    "target_chunk_idx": 10,
    "importance_score": 0.0
   }
  ]
 },
 {
  "source_chunk_idx": 6,
  "source_chunk_text": "Now, the question itself is \"¿Quién actuaba con calma y razonablemente?\" My brain immediately jumps to \"calma\" and \"razonablemente.\" These are behavioral attributes.",
  "target_impacts": [
   {
    "target_chunk_idx": 7,
    "importance_score": 0.0
   },
   {
    "target_chunk_idx": 8,
    "importance_score": 0.0
   }
  ]
 },
 {
  "source_chunk_idx": 7,
  "source_chunk_text": "They require evidence.",
